                            Box.Visible = Config.ESP.Drawing.Boxes.Bounding.Enabled
                            Box.BackgroundColor3 = Config.ESP.Drawing.Boxes.Filled.RGB
                            Box.BackgroundTransparency = Config.ESP.Drawing.Boxes.Filled.Enabled and Config.ESP.Drawing.Boxes.Filled.Transparency or 1
                            Outline.Color = CurrentBoxColor
                            
                            -- Calculate dimensions dynamically
                            local HeadPos = Cam:WorldToViewportPoint(Head.Position + Vector3.new(0, 0.5, 0))
                            local LegPos = Cam:WorldToViewportPoint(RootPart.Position - Vector3.new(0, 3, 0))
                            local BoxHeight = math.abs(HeadPos.Y - LegPos.Y)
                            local BoxWidth = BoxHeight / 1.5
                            
                            Box.Size = UDim2.new(0, BoxWidth, 0, BoxHeight)
                            Box.Position = UDim2.new(0, RootPos.X - BoxWidth / 2, 0, RootPos.Y - BoxHeight / 2)
                            
                            -- Update Chams
                            Highlight.Enabled = Config.ESP.Drawing.Chams.Enabled
                            Highlight.Adornee = Character
                            Highlight.FillColor = CurrentFillColor
                            Highlight.OutlineColor = Config.ESP.Drawing.Chams.OutlineRGB
                            Highlight.FillTransparency = Config.ESP.Drawing.Chams.Fill_Transparency / 100
                            Highlight.OutlineTransparency = Config.ESP.Drawing.Chams.Outline_Transparency / 100
                            Highlight.DepthMode = Config.ESP.Drawing.Chams.Thermal and Enum.HighlightDepthMode.Always or Enum.HighlightDepthMode.Occluded
                            
                            -- Update Name & Metrics
                            Name.Visible = Config.ESP.Drawing.Names.Enabled
                            Name.Text = string.format("<font color='rgb(%d,%d,%d)'>%s</font>", Config.ESP.Drawing.Names.RGB.R*255, Config.ESP.Drawing.Names.RGB.G*255, Config.ESP.Drawing.Names.RGB.B*255, plr.Name)
                            Name.Position = UDim2.new(0, RootPos.X, 0, RootPos.Y - BoxHeight / 2 - 10)
                            
                            Distance.Visible = Config.ESP.Drawing.Distances.Enabled
                            Distance.Text = tostring(math.floor(DistanceFromCam)) .. " studs"
                            Distance.Position = UDim2.new(0, RootPos.X, 0, RootPos.Y + BoxHeight / 2 + 10)
                            
                            -- Update Healthbars
                            Healthbar.Visible = Config.ESP.Drawing.Healthbar.Enabled
                            BehindHealthbar.Visible = Config.ESP.Drawing.Healthbar.Enabled
                            
                            local HealthPercent = Hum.Health / Hum.MaxHealth
                            Healthbar.Size = UDim2.new(0, Config.ESP.Drawing.Healthbar.Width, 0, BoxHeight * HealthPercent)
                            Healthbar.Position = UDim2.new(0, RootPos.X - BoxWidth / 2 - 6, 0, (RootPos.Y - BoxHeight / 2) + (BoxHeight * (1 - HealthPercent)))
                            
                            BehindHealthbar.Size = UDim2.new(0, Config.ESP.Drawing.Healthbar.Width + 2, 0, BoxHeight + 2)
                            BehindHealthbar.Position = UDim2.new(0, RootPos.X - BoxWidth / 2 - 7, 0, RootPos.Y - BoxHeight / 2 - 1)
                            
                            if Config.ESP.FadeOut.OnDistance then
                                Functions.FadeOutOnDist(Box, DistanceFromCam)
                                Functions.FadeOutOnDist(Name, DistanceFromCam)
                                Functions.FadeOutOnDist(Distance, DistanceFromCam)
                                Functions.FadeOutOnDist(Highlight, DistanceFromCam)
                            end
                        else
                            Box.Visible = false; Name.Visible = false; Distance.Visible = false; Weapon.Visible = false; Healthbar.Visible = false; BehindHealthbar.Visible = false; HealthText.Visible = false; Highlight.Enabled = false;
                        end
                    else
                        Box.Visible = false; Name.Visible = false; Distance.Visible = false; Weapon.Visible = false; Healthbar.Visible = false; BehindHealthbar.Visible = false; HealthText.Visible = false; Highlight.Enabled = false;
                    end
                end))
                
                Players_ESP[plr.Name] = {
                    RefreshElements = function() end
                }
            end))
        end
        
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= lplayer then
                ESP(player)
            end
        end
        Players.PlayerAdded:Connect(ESP)
    end
end

