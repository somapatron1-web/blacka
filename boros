local function SetValues()
    if not CurrentGunHeld then return end
    if not CurrentGunHeld:FindFirstChild("Setting") then return end
    local Setting = require(CurrentGunHeld.Setting)
    if not Setting then return end
    if not Original_Weapon_Settings[CurrentGunHeld.Name] then
        Original_Weapon_Settings[CurrentGunHeld.Name] = {}
        for i,v in Setting do
            Original_Weapon_Settings[CurrentGunHeld.Name][i] = v
        end
    end
end

local function ModWeapon(Weapon)
    if not Weapon:FindFirstChild("Setting") then return end
    local Setting = require(Weapon.Setting)
    if not Setting then return end
    
    local Orig = Original_Weapon_Settings[Weapon.Name]
    if not Orig then return end
    
    if Config.South_Bronx._Modifications.DisableJamming then
        Setting.JamChance = 0
    else
        Setting.JamChance = Orig.JamChance
    end
    
    if Config.South_Bronx._Modifications.ModifySpreadValue then
        Setting.Spread = Orig.Spread * (Config.South_Bronx._Modifications.SpreadPercentage / 100)
    else
        Setting.Spread = Orig.Spread
    end
    
    if Config.South_Bronx._Modifications.ModifyRecoilValue then
        Setting.RecoilMin = Orig.RecoilMin * (Config.South_Bronx._Modifications.RecoilPercentage / 100)
        Setting.RecoilMax = Orig.RecoilMax * (Config.South_Bronx._Modifications.RecoilPercentage / 100)
    else
        Setting.RecoilMin = Orig.RecoilMin
        Setting.RecoilMax = Orig.RecoilMax
    end
    
    if Config.South_Bronx._Modifications.Automatic then
        Setting.Automatic = true
    else
        Setting.Automatic = Orig.Automatic
    end
    
    if Config.South_Bronx._Modifications.ModifyFireRate then
        Setting.FireRate = Orig.FireRate * (Config.South_Bronx._Modifications.FireRateSpeed / 100)
    else
        Setting.FireRate = Orig.FireRate
    end
    
    if Config.South_Bronx._Modifications.ModifyReloadSpeed then
        Setting.ReloadSpeed = Orig.ReloadSpeed * (Config.South_Bronx._Modifications.ReloadSpeed / 100)
    else
        Setting.ReloadSpeed = Orig.ReloadSpeed
    end
    
    if Config.South_Bronx._Modifications.ModifyEquipSpeed then
        Setting.EquipSpeed = Orig.EquipSpeed * (Config.South_Bronx._Modifications.EquipSpeed / 100)
    else
        Setting.EquipSpeed = Orig.EquipSpeed
    end
end

